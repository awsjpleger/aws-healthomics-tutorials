{
  "schema": {
    "description": "Schema design to use (1, 2, 3, or 4)",
    "optional": false,
    "useCase": {
        "normalized schema": 1,
        "variant centric schema": 2,
        "sample centric schema": 3,
        "genomic region centric schema": 4
    }
  },
  "destination": {
    "description": "S3 Table Bucket ARN (arn:aws:s3tables:...) or S3 path (s3://...) for Glue catalog. This is a String, not a File.",
    "optional": false,
    "useCase": {
      "normalized schema": "arn:aws:s3tables:<REGION>:<ACCOUNT>:bucket/<BUCKET-NAME>",
      "variant centric schema": "arn:aws:s3tables:<REGION>:<ACCOUNT>:bucket/<BUCKET-NAME>",
      "sample centric schema": "arn:aws:s3tables:<REGION>:<ACCOUNT>:bucket/<BUCKET-NAME>",
      "genomic region centric schema": "arn:aws:s3tables:<REGION>:<ACCOUNT>:bucket/<BUCKET-NAME>"
    }
  },
  "container": {
    "description": "ECR container image URI",
    "optional": false,
    "useCase": {
      "normalized schema": "public.ecr.aws/aws-genomics/healthomics-vcf-loader:v1.1.4",
      "variant centric schema": "public.ecr.aws/aws-genomics/healthomics-vcf-loader:v1.1.4",
      "sample centric schema": "public.ecr.aws/aws-genomics/healthomics-vcf-loader:v1.1.4",
      "genomic region centric schema": "public.ecr.aws/aws-genomics/healthomics-vcf-loader:v1.1.4"
    }
  },
  "namespace": {
    "description": "Iceberg namespace. Auto-determined by schema if omitted.",
    "optional": true
  },
  "batch_size": {
    "description": "Number of VCF records per processing batch (default: 100000)",
    "optional": true
  },
  "vcf_file": {
    "description": "S3 URI to the input VCF or GVCF file (.vcf or .vcf.gz)",
    "optional": false,
    "useCase": {
      "normalized schema": "s3://<BUCKET-NAME>/<PATH-TO-VCF-FILE>",
      "variant centric schema": "s3://<BUCKET-NAME>/<PATH-TO-VCF-FILE>",
      "sample centric schema": "s3://<BUCKET-NAME>/<PATH-TO-VCF-FILE>",
      "genomic region centric schema": "s3://<BUCKET-NAME>/<PATH-TO-VCF-FILE>"
    }
  }
}